#include <stdio.h>

long long checkRecord(int n) {
    long long MOD = 1000000007;

    // dp[a][l] represents:
    // a: total number of 'A' (0 or 1)
    // l: number of consecutive 'L' at the end (0, 1, or 2)
    long long dp[2][3] = {0};

    // Base case: for n=0, there is 1 valid record (empty string)
    dp[0][0] = 1;

    for (int i = 0; i < n; i++) {
        long long new_dp[2][3] = {0};

        for (int a = 0; a < 2; a++) {
            for (int l = 0; l < 3; l++) {
                if (dp[a][l] == 0) continue;

                // 1. Append 'P' (Present)
                // Total 'A' remains 'a', consecutive 'L' resets to 0
                new_dp[a][0] = (new_dp[a][0] + dp[a][l]) % MOD;

                // 2. Append 'L' (Late)
                // Total 'A' remains 'a', consecutive 'L' increases if l < 2
                if (l < 2) {
                    new_dp[a][l + 1] = (new_dp[a][l + 1] + dp[a][l]) % MOD;
                }

                // 3. Append 'A' (Absent)
                // Total 'A' increases to 1 if a == 0, consecutive 'L' resets to 0
                if (a == 0) {
                    new_dp[1][0] = (new_dp[1][0] + dp[a][l]) % MOD;
                }
            }
        }

        // Copy new_dp to dp for the next day
        for (int a = 0; a < 2; a++) {
            for (int l = 0; l < 3; l++) {
                dp[a][l] = new_dp[a][l];
            }
        }
    }

    // Sum all valid states after n days
    long long total = 0;
    for (int a = 0; a < 2; a++) {
        for (int l = 0; l < 3; l++) {
            total = (total + dp[a][l]) % MOD;
        }
    }

    return total;
}
